<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow all cleartext and SSL traffic -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <!-- Explicitly allow Deriv WebSocket and DeepSeek API -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">binaryws.com</domain>
        <domain includeSubdomains="true">deriv.com</domain>
        <domain includeSubdomains="true">deepseek.com</domain>
        <domain includeSubdomains="true">api.deepseek.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">fonts.gstatic.com</domain>
    </domain-config>
</network-security-config>
